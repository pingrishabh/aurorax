# These defaults are baked into docker-compose.yml; this file documents them and
# is handy for the optional local-dev path (running api/worker outside Docker).
# Copy to .env and adjust if needed.

# Postgres: durable source of truth (sessions + message history)
DATABASE_URL=postgresql+asyncpg://chat:chat@localhost:5432/chat

# Redis: work queue (Streams) + token fan-out (Pub/Sub) + durable steer/cancel
REDIS_URL=redis://localhost:6379/0

# Mock-LLM token pacing (seconds), randomised per token to look like typing
TOKEN_MIN_DELAY=0.03
TOKEN_MAX_DELAY=0.12

# "Thinking" pause (seconds) before the first token and after a steer restart
THINK_MIN_DELAY=0.8
THINK_MAX_DELAY=1.6

# TTL/heartbeat for the active-generation marker, draft buffer, and steer/cancel
ACTIVE_TTL=60

# Local-dev only: where `npm run dev` proxies /api (defaults to nginx on 8080)
VITE_API_TARGET=http://localhost:8080
