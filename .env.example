# These defaults are baked into docker-compose.yml; this file documents them
# and is handy for the optional local-dev path (running api/worker outside
# Docker). Copy to .env and adjust if needed.

# Postgres — durable source of truth (sessions + message history)
DATABASE_URL=postgresql+asyncpg://chat:chat@localhost:5432/chat

# Redis — work queue (Streams) + live fan-out / steering / cancel (Pub/Sub)
REDIS_URL=redis://localhost:6379/0

# Mock-LLM token pacing (seconds)
TOKEN_MIN_DELAY=0.03
TOKEN_MAX_DELAY=0.12

# TTL/heartbeat for the active-generation marker and draft buffer (seconds)
ACTIVE_TTL=60

# Local-dev only: where `npm run dev` proxies /api (defaults to nginx on 8080)
VITE_API_TARGET=http://localhost:8080
